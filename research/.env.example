# Env voor de aanbieder-research-crawler + omgevingsplan-poller (Railway of lokaal).
# NIET committen met echte waarden — echte waarden horen in research/.env (gitignored).

# Claude (direct Anthropic API). Kies een model dat web_search_20260209 ondersteunt.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# Supabase — directe Postgres-connectie (pooler-string uit Supabase → Connect → ORMs).
SUPABASE_DB_URL=
# Supabase Storage (service-role) voor het uploaden van kandidaatfoto's.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>

# Gedeeld secret waarmee het CRM /run mag aanroepen.
RESEARCH_TRIGGER_SECRET=<lang-willekeurig-geheim>

# Omgevingsplan-poller → notificatie-endpoint van het CRM (werkopdracht per mail).
# Leeg = de poller signaleert wel in de DB maar mailt niet.
NOTIFY_ENDPOINT=https://crm.opeigenerf.nl/api/notify/gemeente-wijziging
NOTIFY_SECRET=<zelfde-waarde-als-NOTIFY_SECRET-in-Vercel>
