# opeigenerf CRM — environment
# Copy to .env.local and fill in the secret. NEVER commit .env.local.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://eyzhcmdydisaokqzqyli.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_EU17cLZHvd06gCS_6JSYxg_J3BPmMn8

# SECRET — server-side only. Get it from:
# Supabase Dashboard > Project Settings > API > service_role / secret key.
# Used for the marketing-site lead insert and Fase 3 automation. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL of this app (used in magic-link redirects). For local dev keep as-is.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Fase 3 (optioneel, later): Resend voor opvolgmails
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=info@opeigenerf.nl

# M4 — rapportgeneratie via Claude (Vercel AI Gateway).
# Lokaal: AI_GATEWAY_API_KEY van vercel.com/dashboard (AI Gateway). Op Vercel via OIDC.
AI_GATEWAY_API_KEY=
# Model voor het rapport (via gateway). Haiku werkt op het AI Gateway free tier;
# Sonnet/Opus vereisen AI Gateway-credits (top-up). Bump zodra je credits hebt.
REPORT_MODEL=anthropic/claude-haiku-4-5
# Afzender voor de erfscan-mail (Resend, geverifieerd domein).
REPORT_FROM_EMAIL=opeigenerf <noreply@opeigenerf.nl>

# Erfscan-engine (api/erfscan.py)
# Shared secret waarmee de DB-webhook / handmatige trigger de Python-functie aanroept.
ERFSCAN_SECRET=
# Tier 2 — gratis BAG-sleutel bij Kadaster (laat leeg = Tier 2 inactief, Tier 1 draait gewoon).
BAG_API_KEY=
# Tier 2 — DSO 'Regels op de kaart' (optioneel, lastiger te verkrijgen).
DSO_API_KEY=
# URL van de erfscan-engine voor de 'Opnieuw draaien'-knop. Standaard
# ${NEXT_PUBLIC_SITE_URL}/api/erfscan; overschrijf indien de functie elders draait.
ERFSCAN_ENDPOINT=
# BCC-kopie van elk verstuurd rapport (bijv. je eigen archief).
REPORT_BCC=info@opeigenerf.nl

# Google Ads (kosten/lead) — /api/ads-sync haalt dagelijks de spend op.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Manager/MCC-account (zonder streepjes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Het ads-account waarvan je de kosten wilt (zonder streepjes)
GOOGLE_ADS_CUSTOMER_ID=
# Optioneel: pin een API-versie (route valt anders terug op v22/v21/v20)
GOOGLE_ADS_API_VERSION=v22

# Revalidatie publieke site (aparte repo) na aanbieders/woningen-mutaties.
PUBLIC_SITE_REVALIDATE_URL=https://opeigenerf.nl/api/revalidate
REVALIDATE_SECRET=

# HubSpot-sync (CRM -> HubSpot). Private App access-token met scopes:
# crm.objects.{contacts,deals,companies}.read/write + crm.schemas.{contacts,companies}.write.
# Leeg = sync staat uit (route no-opt netjes). Zet ook op Vercel voor productie.
HUBSPOT_ACCESS_TOKEN=

# E-mailflow (nurture): afzender + reply-to (antwoorden komen binnen).
NURTURE_FROM_EMAIL=
NURTURE_REPLY_TO=info@opeigenerf.nl
